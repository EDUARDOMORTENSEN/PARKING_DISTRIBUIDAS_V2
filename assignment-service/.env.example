# Variables de entorno requeridas para el assignment-service

PORT=3002

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5435
DB_USUARIO=asignaciones
DB_CONTRASENA=asignaciones
DB_NOMBRE=asignaciones

# URL del microservicio gestion-usuarios (comunicación interna, sin Kong)
GESTION_USUARIOS_URL=http://localhost:3001

# URL del microservicio de vehiculos (comunicación interna, sin Kong)
VEHICULOS_SERVICE_URL=http://localhost:3000

# URL del JWKS endpoint para validar tokens RS256 (mismo que los otros servicios)
PUBLIC_KEY_URL=http://localhost:3001/auth/jwks
